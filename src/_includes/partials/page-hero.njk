{%- set t = ui[lang] %}
{%- set c = pagedata[lang][pageKey] %}
{%- set root = "/" if lang == "en" else "/id/" %}
<!-- PAGE HERO -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.home[lang].url }}">{{ t.nav.home }}</a><span class="sep">/</span><span class="current">{{ c.hero.breadcrumb }}</span>
      </nav>
      <span class="eyebrow">{{ c.hero.eyebrow }}</span>
      <h1 class="headline-lg">{{ c.hero.heading }}</h1>
      <p class="lede">{{ c.hero.lede }}</p>
    </div>
  </div>
</section>
