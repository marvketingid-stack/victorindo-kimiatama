---
pagination:
  data: langs
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}clients.html{% else %}id/clients.html{% endif %}"
layout: layouts/base.njk
pageKey: clients
slugEn: clients.html
---
{%- set t = ui[lang] %}
{%- set c = pagedata[lang][pageKey] %}
{%- set root = "/" if lang == "en" else "/id/" %}

<style>
  #dist-map { height: 480px; width: 100%; background: var(--surface-container-low); z-index: 1; }
  #dist-map .leaflet-tile { filter: grayscale(.8) contrast(.95); }
  #dist-map .leaflet-popup-content-wrapper, #dist-map .leaflet-popup-tip { border-radius: 0; border: 1px solid var(--stroke-dark); box-shadow: none; }
  #dist-map .leaflet-popup-content { font-family: 'Inter', sans-serif; font-size: 13px; line-height: 20px; margin: 12px 16px; }
  #dist-map .leaflet-popup-content strong { font-family: 'Montserrat', sans-serif; font-size: 13.5px; }
  #dist-map .leaflet-popup-content .region { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: .06em; text-transform: uppercase; color: var(--brand-crimson); display: block; margin-top: 2px; }
  #dist-map .leaflet-container a.leaflet-popup-close-button { border-radius: 0; }
  @media (max-width: 720px) { #dist-map { height: 340px; } }
</style>

{% include "partials/page-hero.njk" %}

<!-- CLIENT ECOSYSTEM -->
<section class="section">
  <div class="container">
    {%- for group in c.groups %}
    <div class="client-group">
      <h3>{{ group.title }}</h3>
      <div class="client-grid">
        {%- for client in group.clients %}
        <div class="client-cell reveal"><span class="cname">{{ client.name }}</span><span class="csub">{{ client.sub }}</span></div>
        {%- endfor %}
      </div>
    </div>
    {%- endfor %}
  </div>
</section>

<!-- CERTIFICATIONS -->
<section class="section section-cream" id="certifications">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ c.certs.eyebrow }}</span>
      <h2 class="headline-lg">{{ c.certs.heading }}</h2>
      <p class="lede body-md">{{ c.certs.lede }}</p>
    </div>
    <div class="grid-3 mb-24">
      {%- for card in c.certs.isoCards %}
      <div class="cert-card reveal">
        <div class="cert-code">{{ card.code }}<small>{{ card.subtitle }}</small></div>
        <p>{{ card.desc }}</p>
      </div>
      {%- endfor %}
    </div>
    <div class="grid-2">
      {%- for card in c.certs.otherCards %}
      <div class="cert-card reveal">
        <div class="cert-code">{{ card.code }}<small>{{ card.subtitle }}</small></div>
        <p>{{ card.desc }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- DISTRIBUTION MAP -->
<section class="section" id="distribution">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ c.distribution.eyebrow }}</span>
      <h2 class="headline-lg">{{ c.distribution.heading }}</h2>
      <p class="lede body-md">{{ c.distribution.lede }}</p>
    </div>

    {%- if distribution.embedUrl %}
    <div class="map-embed reveal">
      <iframe
        title="{{ c.distribution.heading }}"
        src="{{ distribution.embedUrl }}"
        loading="lazy"
        style="height:480px;"
        allowfullscreen></iframe>
    </div>
    {%- else %}
    <div class="map-wrap reveal" style="padding:0;overflow:hidden;">
      <div id="dist-map" role="img" aria-label="{{ c.distribution.mapAria }}"></div>
    </div>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    (function () {
      var points = {{ distribution.points | dump | safe }};
      var map = L.map('dist-map', { scrollWheelZoom: false });
      L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 12,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);
      var bounds = [];
      points.forEach(function (p) {
        L.circleMarker([p.lat, p.lng], {
          radius: 7, color: '#ffffff', weight: 2,
          fillColor: '#9A1208', fillOpacity: 0.95
        }).addTo(map).bindPopup('<strong>' + p.name + '</strong><span class="region">' + p.region + '</span>');
        bounds.push([p.lat, p.lng]);
      });
      map.fitBounds(bounds, { padding: [28, 28] });
    })();
    </script>
    {%- endif %}

    <div class="region-grid">
      {%- for region in c.distribution.regions %}
      <div class="region-col reveal">
        <h3>{{ region.title }}</h3>
        <ul>
          {%- for item in region.items %}
          <li><strong>{{ item.region }}</strong>{% if item.cities %} — {{ item.cities }}{% endif %}</li>
          {%- endfor %}
        </ul>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{% include "partials/cta-band.njk" %}
