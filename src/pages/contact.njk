---
pagination:
  data: langs
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}contact.html{% else %}id/contact.html{% endif %}"
layout: layouts/base.njk
pageKey: contact
slugEn: contact.html
---
{%- set t = ui[lang] %}
{%- set c = pagedata[lang][pageKey] %}
{%- set root = "/" if lang == "en" else "/id/" %}

{% include "partials/page-hero.njk" %}

<!-- CONTACT -->
<section class="section">
  <div class="container">
    <div class="contact-grid">
      <div>
        <span class="eyebrow">{{ c.info.eyebrow }}</span>
        <h2 class="headline-md mb-24">{{ c.info.heading }}</h2>
        <div class="info-block reveal">
          <div class="info-row">
            <div class="ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="square"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
            </div>
            <div>
              <h4>{{ c.info.addressLabel }}</h4>
              <p>{{ site.address }}</p>
            </div>
          </div>
          <div class="info-row">
            <div class="ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="square"><path d="M5 4h4l2 5-2.5 1.5a12 12 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
            </div>
            <div>
              <h4>{{ c.info.phoneLabel }}</h4>
              <p><a href="{{ site.phoneHref }}">{{ site.phone }}</a></p>
            </div>
          </div>
          <div class="info-row">
            <div class="ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="square"><rect x="3" y="5" width="18" height="14"/><path d="M3 7l9 6 9-6"/></svg>
            </div>
            <div>
              <h4>{{ c.info.emailLabel }}</h4>
              <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
            </div>
          </div>
          <div class="info-row">
            <div class="ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="square"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>
            </div>
            <div>
              <h4>{{ c.info.websiteLabel }}</h4>
              <p><a href="{{ site.websiteUrl }}" rel="noopener">{{ site.websiteLabel }}</a></p>
            </div>
          </div>
        </div>

        <div class="card card-accent card-pad mt-32 reveal">
          <span class="label-caps text-crimson">{{ c.profileCard.label }}</span>
          <p class="body-sm text-muted mt-16 mb-16">{{ c.profileCard.desc }}</p>
          <a class="btn btn-outline" href="{{ site.profilePdf }}" download>{{ t.ctaDownload }}</a>
        </div>
      </div>

      <div>
        <span class="eyebrow">{{ c.form.eyebrow }}</span>
        <h2 class="headline-md mb-24">{{ c.form.heading }}</h2>
        <form class="form-panel reveal" id="inquiry-form" novalidate>
          <div class="form-grid">
            <div class="form-field" data-field="name">
              <label for="f-name">{{ c.form.nameLabel }} <span class="req">*</span></label>
              <input type="text" id="f-name" name="name" placeholder="{{ c.form.namePlaceholder }}" autocomplete="name" required>
              <span class="err">{{ c.form.nameError }}</span>
            </div>
            <div class="form-field" data-field="company">
              <label for="f-company">{{ c.form.companyLabel }}</label>
              <input type="text" id="f-company" name="company" placeholder="{{ c.form.companyPlaceholder }}" autocomplete="organization">
            </div>
            <div class="form-field" data-field="email">
              <label for="f-email">{{ c.form.emailLabel }} <span class="req">*</span></label>
              <input type="email" id="f-email" name="email" placeholder="{{ c.form.emailPlaceholder }}" autocomplete="email" required>
              <span class="err">{{ c.form.emailError }}</span>
            </div>
            <div class="form-field" data-field="phone">
              <label for="f-phone">{{ c.form.phoneLabel }}</label>
              <input type="tel" id="f-phone" name="phone" placeholder="{{ c.form.phonePlaceholder }}" autocomplete="tel">
            </div>
            <div class="form-field full" data-field="industry">
              <label for="f-industry">{{ c.form.industryLabel }} <span class="req">*</span></label>
              <select id="f-industry" name="industry" required>
                <option value="">{{ c.form.industryDefault }}</option>
                {%- for opt in c.form.industryOptions %}
                <option>{{ opt }}</option>
                {%- endfor %}
              </select>
              <span class="err">{{ c.form.industryError }}</span>
            </div>
            <div class="form-field full" data-field="message">
              <label for="f-message">{{ c.form.messageLabel }} <span class="req">*</span></label>
              <textarea id="f-message" name="message" rows="5" placeholder="{{ c.form.messagePlaceholder }}" required></textarea>
              <span class="err">{{ c.form.messageError }}</span>
            </div>
          </div>
          <div class="mt-24">
            <button class="btn btn-primary" type="submit">{{ c.form.submit }} <span class="arrow">&rarr;</span></button>
          </div>
          <p class="form-note">{{ c.form.note | replace("*", '<span class="text-crimson">*</span>') | safe }}</p>
          <div class="form-success" id="form-success">{{ c.form.success | safe }}</div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FACTORY LOCATION -->
<section class="section section-cream">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ c.location.eyebrow }}</span>
      <h2 class="headline-lg">{{ c.location.heading }}</h2>
      <p class="lede body-md">{{ c.location.lede }}</p>
    </div>
    <div class="map-embed reveal">
      <iframe
        title="{{ c.location.mapTitle }}"
        src="{{ site.mapEmbedUrl }}"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen></iframe>
    </div>
  </div>
</section>
